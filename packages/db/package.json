{
  "name": "@repo/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./schema/enums": {
      "types": "./src/schema/enums.ts",
      "default": "./src/schema/enums.ts"
    },
    "./schema/business": {
      "types": "./src/schema/business.ts",
      "default": "./src/schema/business.ts"
    },
